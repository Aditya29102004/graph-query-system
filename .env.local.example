# Copy to `.env.local` and paste from Supabase → Project Settings → API:
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon / public key → NEXT_PUBLIC_SUPABASE_ANON_KEY

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Required for npm run load-o2c (Dashboard → Settings → API → service_role — server only)
SUPABASE_SERVICE_ROLE_KEY=

# Natural language → SQL (OpenRouter default, or LLM_PROVIDER=gemini for Google AI)
LLM_API_KEY=
# openrouter | gemini
LLM_PROVIDER=openrouter
# OpenRouter model id, e.g. google/gemini-2.0-flash-001 ; Gemini: gemini-2.0-flash
LLM_MODEL=

# Postgres URI for /api/query SQL execution (Supabase → Settings → Database → URI)
DATABASE_URL=

# Optional OpenRouter headers
# OPENROUTER_APP_URL=
# OPENROUTER_APP_TITLE=
